{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JSON Toolkit",
  "version": "0.1.0",
  "identifier": "dev.junhey.json-toolkit",
  "build": {
    "beforeDevCommand": "pnpm wasm:build && pnpm --filter web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm wasm:build && pnpm --filter web build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "JSON Toolkit",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
