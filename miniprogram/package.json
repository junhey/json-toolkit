{
  "name": "json-toolkit-miniprogram",
  "version": "0.1.0",
  "private": true,
  "description": "JSON Toolkit WeChat Mini Program - Format, minify, sort, query JSON on the go",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "iOS >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.0.9",
    "@tarojs/helper": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/react": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "4.0.9",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/react": "^18.3.12",
    "babel-preset-taro": "4.0.9",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0"
  }
}
